# ─────────────────────────────────────────────
# ERP CENTRAL À BÉTON - Configuration Serveur
# ─────────────────────────────────────────────

# Serveur
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Base de données Supabase
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# JWT Secrets (générer avec : openssl rand -hex 64)
JWT_ACCESS_SECRET=votre_secret_access_token_tres_long_et_securise
JWT_REFRESH_SECRET=votre_secret_refresh_token_tres_long_et_securise
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Logs
LOG_LEVEL=info
LOG_DIR=logs

# Service ML Python (optionnel — fallback JS si indisponible)
ML_SERVICE_URL=http://localhost:8001
